# LLM - Groq (https://console.groq.com/keys)
GROQ_API_KEY=

# Reranking - Cohere (https://dashboard.cohere.com/api-keys) - free tier, usado a partir do Dia 4
COHERE_API_KEY=

# Banco vetorial - Qdrant local (Docker)
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Banco estruturado - Postgres local (Docker)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=startup_radar
POSTGRES_USER=radar_user
POSTGRES_PASSWORD=radar_pass

# Modelo Groq a ser usado pelos agentes
GROQ_MODEL=llama-3.3-70b-versatile

# Extracao estruturada de startups
EXTRACTION_PROVIDER=heuristic
EXTRACTION_MODEL=llama-3.3-70b-versatile
EXTRACTION_MAX_EVIDENCES=4
EXTRACTION_MAX_CHARS_PER_EVIDENCE=1800
